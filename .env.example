APP_NAME=GarageON
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001
GARAGEON_CNAME_TARGET=
GOOGLE_PLACES_API_KEY=
HTTP_PORT=8001
HTTPS_PORT=443

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=garageon
DB_USERNAME=garageon
DB_PASSWORD=garageon
DB_ROOT_PASSWORD=garageon_root
MYSQL_DATABASE=garageon
MYSQL_USER=garageon
MYSQL_PASSWORD=garageon

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="onboarding@resend.dev"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

VEHICLE_PLATE_PROVIDER=apiplacas
APIPLACAS_TOKEN=
APIPLACAS_URL=https://wdapi2.com.br/consulta
# Para usar BrasilDados/Apify, troque VEHICLE_PLATE_PROVIDER para brasildados.
BRASILDADOS_TOKEN=
BRASILDADOS_VEHICLE_PLATE_URL=https://brasildados--consulta-veiculo-por-placa.apify.actor/check

EVOLUTION_GO_URL=http://evolution-go:8080
EVOLUTION_GO_API_KEY=
EVOLUTION_GO_TIMEOUT=12
EVOLUTION_GO_PORT=8080
# URL base que a Evolution usa para entregar o webhook ao GarageON.
# Deve ser alcançável de dentro do container da Evolution (mesma rede Docker).
# Sem isso, a Evolution tentaria o APP_URL público (ex.: localhost) e falharia.
EVOLUTION_GO_WEBHOOK_BASE_URL=http://nginx
EVOLUTION_POSTGRES_DB=evolution_go
EVOLUTION_POSTGRES_USER=evolution
EVOLUTION_POSTGRES_PASSWORD=evolution

# Atendente virtual (Laravel AI SDK). As chaves reais são por tenant, salvas
# criptografadas em virtual_attendants.api_key. Estas envs são apenas fallback
# opcional a nível de plataforma; podem ficar vazias.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
